    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.flatMap((inputItem, index) => {\n  const raw = inputItem.json.text;\n\n  const clean = raw\n    .replace(/```json/g, '')\n    .replace(/```/g, '')\n    .trim();\n\n  const jsonStart = clean.indexOf('{');\n  const jsonEnd = clean.lastIndexOf('}') + 1;\n  const jsonString = clean.slice(jsonStart, jsonEnd);\n  const parsed = JSON.parse(jsonString);\n\n  const nama_client = parsed.nama_client;\n  const nomor_kontrak = parsed.nomor_kontrak;\n  const total_nilai_kontrak = parsed.total_nilai_kontrak;\n\n  // ✅ Ambil fileId sesuai index item\n  const fileId = $('Limit').all()[index].json.fileId;\n\n  return parsed.termin.map(item => ({\n    json: {\n      nama_client,\n      nomor_kontrak,\n      total_nilai_kontrak,\n      nama_termin: item.nama,\n      persentase: item.persentase,\n      nominal: item.nominal,\n      tanggal_target: item.tanggal_target,\n      status: 'Pending',\n      fileId\n    }\n  }));\n});"
      },
