    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n\n  // Ambil link dari Google Sheets\n  const fileUrl = item.json[\"Bukti Kontrak Pembayaran\"];\n\n  let fileId = '';\n\n  // Format:\n  // https://drive.google.com/file/d/FILE_ID/view\n  const match1 = fileUrl.match(/\\/d\\/([a-zA-Z0-9_-]+)/);\n\n  // Format:\n  // https://drive.google.com/open?id=FILE_ID\n  const match2 = fileUrl.match(/[?&]id=([a-zA-Z0-9_-]+)/);\n\n  if (match1 && match1[1]) {\n    fileId = match1[1];\n  } else if (match2 && match2[1]) {\n    fileId = match2[1];\n  }\n\n  // Buat link view Google Drive\n  const driveLink = `$input.first().json['Bukti Kontrak Pembayaran']`;\n\n  return {\n    json: {\n      ...item.json,\n      fileId,\n      driveLink\n    }\n  };\n});"
      },
