        "message": "=<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"UTF-8\">\n</head>\n\n<body style=\"font-family: Arial, sans-serif; background-color:#f4f6f8; padding:20px;\">\n\n  <div style=\"max-width:600px; margin:auto; background:#ffffff; border-radius:10px; padding:30px; border:1px solid #e0e0e0;\">\n\n    <h2 style=\"color:#1f2937; margin-bottom:10px;\">\n      Approval Pembayaran Kontrak\n    </h2>\n\n    <p style=\"color:#4b5563; font-size:14px;\">\n      Kepada Yth. <b>Manager Finance</b>,\n    </p>\n\n    <p style=\"color:#4b5563; line-height:1.6;\">\n      Terdapat pengajuan pembayaran termin kontrak kerja sama yang memerlukan proses review dan approval dari tim Finance.\n    </p>\n\n    <div style=\"background:#f9fafb; border:1px solid #d1d5db; border-radius:8px; padding:20px; margin-top:20px;\">\n\n      <h3 style=\"margin-top:0; color:#111827;\">\n        Detail Kontrak\n      </h3>\n\n      <table style=\"width:100%; border-collapse:collapse; font-size:14px;\">\n\n        <tr>\n          <td style=\"padding:8px 0; color:#6b7280;\">Perusahaan</td>\n          <td style=\"padding:8px 0;\"><b>PT Glory</b></td>\n        </tr>\n\n        <tr>\n          <td style=\"padding:8px 0; color:#6b7280;\">Nomor Kontrak</td>\n          <td style=\"padding:8px 0;\">\n            {{ $json['Nomor Kontrak'] }}\n          </td>\n        </tr>\n\n        <tr>\n          <td style=\"padding:8px 0; color:#6b7280;\">Nama Client</td>\n          <td style=\"padding:8px 0;\">\n            {{ $json['Nama Client'] }}\n          </td>\n        </tr>\n\n        <tr>\n          <td style=\"padding:8px 0; color:#6b7280;\">Total Nilai Kontrak</td>\n          <td style=\"padding:8px 0;\">\n            {{ $json['Total Kontrak'] }}\n          </td>\n        </tr>\n\n        <tr>\n          <td style=\"padding:8px 0; color:#6b7280;\">Termin Pembayaran</td>\n          <td style=\"padding:8px 0;\">\n            {{ $json['Nama Termin'] }}\n          </td>\n        </tr>\n\n        <tr>\n          <td style=\"padding:8px 0; color:#6b7280;\">Persentase</td>\n          <td style=\"padding:8px 0;\">\n            {{ $json['Persentase'] }}\n          </td>\n        </tr>\n\n        <tr>\n          <td style=\"padding:8px 0; color:#6b7280;\">Nominal Pembayaran</td>\n          <td style=\"padding:8px 0;\">\n            {{ $json['Nominal'] }}\n          </td>\n        </tr>\n\n        <tr>\n          <td style=\"padding:8px 0; color:#6b7280;\">Target Pembayaran</td>\n          <td style=\"padding:8px 0;\">\n            {{ $json['Tanggal Target'] }}\n          </td>\n        </tr>\n\n      </table>\n    </div>\n\n    <p style=\"margin-top:25px; color:#4b5563; line-height:1.6;\">\n      Mohon untuk melakukan pengecekan dokumen pendukung dan memberikan persetujuan pembayaran sesuai jadwal yang telah ditentukan.\n    </p>\n\n    <div style=\"margin-top:30px; text-align:center;\">\n\n      <a \n        href=\"https://drive.google.com/file/d/{{ $json['File ID'] }}/view\"\n        target=\"_blank\"\n        style=\"background:#2563eb; color:white; text-decoration:none; padding:12px 24px; border-radius:6px; display:inline-block;\"\n      >\n        Lihat Dokumen Kontrak\n      </a>\n\n    </div>\n\n    <hr style=\"margin:30px 0; border:none; border-top:1px solid #e5e7eb;\">\n\n    <p style=\"font-size:12px; color:#9ca3af; text-align:center;\">\n      Email ini dibuat otomatis oleh Finance Automation System – PT Glory\n    </p>\n\n  </div>\n\n</body>\n</html>",
